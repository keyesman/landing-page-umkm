---
// src/components/Hero.astro
import { clientData } from '../data/clientConfig';

const { hero, global } = clientData;

// Membuat pesan WhatsApp otomatis agar pembeli tidak bingung mau mengetik apa
const waMessage = encodeURIComponent(`Halo admin, saya tertarik dengan promo ${global.brandName} dari website. Apakah masih tersedia?`);
const waLink = `https://wa.me/${global.whatsappNumber}?text=${waMessage}`;
---

<section class="relative pt-16 pb-20 lg:pt-24 lg:pb-28 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      
      <div class="text-center lg:text-left">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight mb-6">
          {hero.headline}
        </h1>
        <p class="text-lg sm:text-xl text-slate-600 mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
          {hero.subHeadline}
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-4">
          <a 
            href={waLink} 
            target="_blank" 
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center bg-primary text-white px-8 py-4 rounded-full font-bold text-lg shadow-lg shadow-primary/30 hover:opacity-90 hover:-translate-y-1 transition-all duration-200"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="mr-2" viewBox="0 0 16 16">
              <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592zm3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.729.729 0 0 0-.529.247c-.182.198-.691.677-.691 1.654 0 .977.71 1.916.81 2.049.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232z"/>
            </svg>
            {hero.ctaText}
          </a>
        </div>
      </div>

      <div class="relative mx-auto w-full max-w-lg lg:max-w-full">
        <div class="absolute inset-0 bg-primary/10 rounded-[2rem] transform translate-x-4 translate-y-4 -z-10"></div>
        <img 
          src={hero.mediaUrl} 
          alt={global.brandName} 
          class="w-full h-auto rounded-[2rem] shadow-xl object-cover object-center aspect-video lg:aspect-[4/3] border border-slate-100"
          loading="eager"
        />
      </div>

    </div>
  </div>
</section>
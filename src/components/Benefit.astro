---
// src/components/Benefit.astro
import { clientData } from '../data/clientConfig';

const { benefits } = clientData;
---

<section id="benefit" class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl font-extrabold text-slate-900 sm:text-4xl mb-4">
        Kenapa harus beli Asics?
      </h2>
      <p class="text-lg text-slate-600">
        Kami memahami apa yang Anda butuhkan. Inilah keunggulan yang kami hadirkan khusus untuk Anda.
      </p>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {benefits.map((benefit) => (
        <div 
          class="relative p-8 rounded-2xl shadow-sm border border-slate-200 hover:shadow-lg hover:-translate-y-1 transition-all duration-300 group overflow-hidden"
          style="background-color: color-mix(in srgb, var(--color-primary) 5%, white);"
        >
          <div class="absolute top-0 left-0 w-full h-1.5 bg-primary opacity-30 group-hover:opacity-100 transition-opacity duration-300"></div>
          
          <div 
            class="w-14 h-14 text-primary rounded-xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300"
            style="background-color: color-mix(in srgb, var(--color-primary) 15%, white);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" viewBox="0 0 256 256">
              <path d="M128,24A104,104,0,1,0,232,128,104.11,104.11,0,0,0,128,24Zm45.66,85.66-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35a8,8,0,0,1,11.32,11.32Z"></path>
            </svg>
          </div>
          
          <h3 class="text-xl font-bold text-slate-900 mb-3 leading-tight relative z-10">
            {benefit.title}
          </h3>
          <p class="text-slate-700 leading-relaxed relative z-10">
            {benefit.description}
          </p>
          
        </div>
      ))}
    </div>

  </div>
</section>
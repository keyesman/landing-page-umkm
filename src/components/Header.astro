---
// src/components/Header.astro
import { clientData } from '../data/clientConfig';

const menuItems = [
  { name: 'Benefit', href: '#benefit' },
  { name: 'Testimoni', href: '#testimonial' },
  { name: 'Harga', href: '#pricing' },
  { name: 'FAQ', href: '#faq' },
];
---

<header class="w-full bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-slate-100">
  <div class="max-w-6xl mx-auto px-4 h-20 flex items-center justify-between">
    
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img src="/shopifun.png" alt={clientData.global.brandName} class="h-8 w-auto" />
      <span class="text-xl font-extrabold text-slate-900 tracking-tight">
        {clientData.global.brandName}
      </span>
    </a>

    <!-- Desktop Menu (Hidden di mobile) -->
    <nav class="hidden md:flex items-center gap-8">
      {menuItems.map((item) => (
        <a href={item.href} class="text-sm font-semibold text-slate-600 hover:text-primary">{item.name}</a>
      ))}
      <a href={`https://wa.me/${clientData.global.whatsappNumber}`} class="text-sm font-bold bg-primary text-white px-5 py-2 rounded-full hover:opacity-90">
        Gratis Konsultasi!
      </a>
    </nav>

    <!-- Hamburger Icon (Hanya tampil di mobile) -->
    <label for="menu-toggle" class="md:hidden cursor-pointer p-2">
      <svg class="w-6 h-6 text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
    </label>
  </div>

  <!-- Checkbox tersembunyi untuk kontrol menu -->
  <input type="checkbox" id="menu-toggle" class="hidden peer" />

  <!-- Mobile Menu (Muncul hanya saat checkbox dicentang) -->
  <div class="hidden peer-checked:flex flex-col p-4 bg-white border-b border-slate-100 md:hidden">
    {menuItems.map((item) => (
      <a href={item.href} class="py-3 text-sm font-semibold text-slate-700 border-b border-slate-50">{item.name}</a>
    ))}
  </div>
</header>